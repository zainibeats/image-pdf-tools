# Local edge vision model settings.
# Copy this file to .env and edit the values for your local AI server.

# openai-compatible expects POST {RECEIPT_VISION_BASE_URL}/chat/completions.
# ollama expects POST {RECEIPT_VISION_BASE_URL}/api/generate.
RECEIPT_VISION_PROVIDER=openai-compatible
RECEIPT_VISION_BASE_URL=http://127.0.0.1:8000/v1
RECEIPT_VISION_MODEL=mistralai/ministral-3-3b

# Optional.
RECEIPT_VISION_API_KEY=
RECEIPT_VISION_TIMEOUT=90
RECEIPT_VISION_MAX_IMAGE_EDGE=768
RECEIPT_VISION_ALLOW_REMOTE=false
