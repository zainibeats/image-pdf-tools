# Local edge vision model settings.
# Copy this file to .env and edit the values for your local AI server.

# openai-compatible expects POST {RECEIPT_VISION_BASE_URL}/chat/completions.
# ollama expects POST {RECEIPT_VISION_BASE_URL}/api/generate.
RECEIPT_VISION_PROVIDER=openai-compatible
RECEIPT_VISION_BASE_URL=http://127.0.0.1:8000/v1
RECEIPT_VISION_MODEL=mistralai/ministral-3-3b

# Optional.
RECEIPT_VISION_API_KEY=
RECEIPT_VISION_TIMEOUT=90
RECEIPT_VISION_MAX_IMAGE_EDGE=768
RECEIPT_VISION_ALLOW_REMOTE=false

# Docker-only knobs.
# PYTHON_VERSION controls the Python base image used by docker compose build.
# OLLAMA_TAG controls the optional local Ollama sidecar image tag.
# DOCKER_RECEIPT_VISION_BASE_URL points from the app container to a model server
# on the host machine. Do not use 127.0.0.1 for host services from Docker.
PYTHON_VERSION=3.12
OLLAMA_TAG=latest
OLLAMA_MODEL=qwen3-vl:8b
OLLAMA_TIMEOUT=180
DOCKER_RECEIPT_VISION_PROVIDER=openai-compatible
DOCKER_RECEIPT_VISION_BASE_URL=http://host.docker.internal:8000/v1
